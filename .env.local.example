# ─── App ────────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com/dashboard and find these in Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — used for webhooks and admin operations (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required for project generation. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Required for credit purchases. Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Credit pack price IDs — create products in Stripe Dashboard
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_AGENCY=price_...

# Subscription price IDs (if using subscription tiers)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
STRIPE_TEAM_ANNUAL_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...

# ─── Resend (optional — for purchase/generation emails) ─────────────────────
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Origo <noreply@yourdomain.com>

# ─── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
